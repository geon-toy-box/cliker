# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# toybox: local proof + runtime isolation, not source
docs/tasks/**/evidence/
docs/tasks/**/.status
docs/.errors/
.worktrees/
.factory/

# Android release signing — NEVER commit keystore or passwords.
# See https://flutter.dev/to/reference-keystore
android/key.properties
android/upload-keystore.jks
**/*.jks
**/*.keystore
